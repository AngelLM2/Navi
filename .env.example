OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_HOST=
OLLAMA_KEEP_ALIVE=15m
NAVI_ENV_FILE=.env
NAVI_DATA_DIR=data
NAVI_DATA_COMPAT_MIRROR_ENABLED=false
OLLAMA_NUM_CTX_COMMAND=1024
OLLAMA_NUM_CTX_KNOWLEDGE=1280
OLLAMA_NUM_CTX_TEXT=1280
OLLAMA_MAX_PREDICT_TEXT=620
NAVI_GENERATED_FILES_DIR=generated_files
NAVI_TTS_ENGINE=sapi
NAVI_TTS_VOICE_HINT=zira
NAVI_TTS_RATE=1.2
NAVI_TTS_VOLUME=100
NAVI_TTS_URL_POLICY=domain_only
NAVI_WEB_HEADLESS=false
NAVI_WEB_SLOW_MO_MS=0
NAVI_WEB_USE_DEFAULT_BROWSER_FOR_LIVE=true
NAVI_WEB_LIVE_PROFILES=youtube,google,netflix,twitch,spotify,primevideo,disneyplus,max,globoplay
NAVI_WEB_CONSUMER_PROFILES=youtube,netflix,twitch,spotify,primevideo,disneyplus,max,globoplay,instagram,tiktok,facebook,x,twitter,reddit
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_FALLBACK_MODELS=llama-3.3-70b-versatile,openai/gpt-oss-120b
GEMINI_MODEL=gemini-1.5-flash
VOSK_MODEL_PATH=vosk-model-en-us-0.22
VOSK_FALLBACK_MODEL_PATH=vosk-model-small-en-us-0.15
VOSK_TARGET_VOCAB_SIZE=7000
VOSK_PARTIAL_MIN_CHARS=3

GROQ_API_KEY=
GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
NETFLIX_PASS=

GOOGLE_CLIENT_SECRETS_FILE=google_client_secrets.json
GOOGLE_TOKEN_FILE=data/runtime/google_token.json

LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
 
CONTEXT_CORRECTION_ENABLED=true
SMART_ROUTING_ENABLED=true
GROQ_ENABLED=true
GEMINI_ENABLED=true
INTEGRATIONS_GMAIL_ENABLED=true
INTEGRATIONS_CALENDAR_ENABLED=true
INTEGRATIONS_TELEGRAM_ENABLED=true
INTEGRATIONS_DRIVE_ENABLED=true
INTEGRATIONS_LINKEDIN_ENABLED=true
INTEGRATIONS_WHATSAPP_ENABLED=true
AUTO_REPLY_ENABLED=false
PLAYWRIGHT_AUTOMATION_ENABLED=true
FILE_CREATION_ENABLED=true
